{
  "metadata": {
    "name": "fifth-pod",
    "namespace": "default"
  },
  "kind": "Pod",
  "apiVersion": "v1",
  "spec": {
    "hostname": "fifth-pod",
    "dnsPolicy": "ClusterFirst",
    "terminationGracePeriodSeconds": 0,
    "containers": [
      {
        "image": "rockylinux/rockylinux:9",
        "imagePullPolicy": "IfNotPresent",
        "name": "fifth-pod",
        "command": [
          "/usr/bin/bash"
        ],
        "args": [
          "-c",
          "echo 'I am fifth pod. I have no labels.'; sleep inf"
        ]
      }
    ],
    "restartPolicy": "Always"
  }
}
